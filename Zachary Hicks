<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Your Uber & Lyft Driver Zachary - Colorado Springs, Woodland Park, Denver & the Rockies. Army veteran, proud dad of three, and your friendly local driver." />
  <title>Your Driver Zachary | Colorado Rockies</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --pine:    #2D4A3E;
      --sage:    #5C8A6F;
      --cream:   #FAF6EF;
      --amber:   #D4822A;
      --gold:    #F0B84B;
      --stone:   #6B6257;
      --white:   #FFFFFF;
      --shadow:  rgba(45,74,62,0.12);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--cream);
      color: var(--pine);
      line-height: 1.65;
    }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(160deg, var(--pine) 0%, #1a3329 60%, #0f2019 100%);
      color: var(--white);
      padding: 3.5rem 1.5rem 4rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '⛰';
      position: absolute;
      font-size: 18rem;
      opacity: 0.04;
      bottom: -3rem;
      left: 50%;
      transform: translateX(-50%);
      pointer-events: none;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--amber);
      color: var(--white);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.35rem 0.9rem;
      border-radius: 2rem;
      margin-bottom: 1.2rem;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 8vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 0.6rem;
    }

    .hero h1 span { color: var(--gold); }

    .hero-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.78);
      max-width: 480px;
      margin: 0 auto 2rem;
    }

    .hero-chips {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
      margin-bottom: 2.2rem;
    }

    .chip {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.22);
      color: var(--white);
      font-size: 0.82rem;
      font-weight: 600;
      padding: 0.3rem 0.85rem;
      border-radius: 2rem;
    }

    .hero-btns {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.7rem 1.4rem;
      border-radius: 2rem;
      font-family: 'Nunito', sans-serif;
      font-size: 0.92rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform 0.15s, box-shadow 0.15s;
      cursor: pointer;
      border: none;
    }

    .btn:hover { transform: translateY(-2px); box-shadow: 0 6px 18px var(--shadow); }

    .btn-uber { background: var(--white); color: #000; }
    .btn-lyft { background: #FF00BF; color: var(--white); }
    .btn-tip  { background: var(--amber); color: var(--white); }
    .btn-outline {
      background: transparent;
      border: 2px solid rgba(255,255,255,0.5);
      color: var(--white);
    }

    /* ── SECTION BASE ── */
    section { padding: 3rem 1.5rem; }

    .section-label {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 0.5rem;
    }

    h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 5vw, 2.2rem);
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 1rem;
    }

    /* ── ABOUT ── */
    .about { background: var(--white); }

    .about-inner {
      max-width: 680px;
      margin: 0 auto;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .about-card {
      background: var(--cream);
      border-radius: 1rem;
      padding: 1rem 1.1rem;
    }

    .about-card .icon { font-size: 1.4rem; margin-bottom: 0.3rem; }
    .about-card strong { display: block; font-size: 0.82rem; color: var(--stone); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.2rem; }
    .about-card p { font-size: 0.92rem; font-weight: 600; color: var(--pine); }

    .about-quote {
      border-left: 4px solid var(--sage);
      padding-left: 1rem;
      margin-top: 1.5rem;
      font-size: 1rem;
      color: var(--stone);
      font-style: italic;
    }

    /* ── KIDS BANNER ── */
    .kids-banner {
      background: linear-gradient(135deg, var(--sage), var(--pine));
      color: var(--white);
      text-align: center;
      padding: 2.5rem 1.5rem;
    }

    .kids-banner h2 { color: var(--gold); margin-bottom: 0.5rem; }
    .kids-banner p { opacity: 0.88; max-width: 480px; margin: 0 auto; }

    .kids-names {
      display: flex;
      justify-content: center;
      gap: 1.2rem;
      margin-top: 1.2rem;
      flex-wrap: wrap;
    }

    .kid-tag {
      background: rgba(255,255,255,0.12);
      border-radius: 1rem;
      padding: 0.5rem 1.1rem;
      font-weight: 700;
      font-size: 0.95rem;
    }

    /* ── AREA GUIDES ── */
    .guides { background: var(--cream); }
    .guides-inner { max-width: 680px; margin: 0 auto; }

    .guide-list {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 1.2rem;
    }

    .guide-region {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--stone);
      margin-top: 1rem;
      margin-bottom: 0.3rem;
    }

    .guide-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--white);
      border-radius: 0.85rem;
      padding: 0.85rem 1.1rem;
      text-decoration: none;
      color: var(--pine);
      font-weight: 700;
      font-size: 0.95rem;
      box-shadow: 0 2px 8px var(--shadow);
      transition: transform 0.12s, box-shadow 0.12s;
    }

    .guide-link:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px var(--shadow);
    }

    .guide-link .arrow { color: var(--amber); font-size: 1rem; }

    /* ── TIPS / RIDE INFO ── */
    .ride-info { background: var(--white); }
    .ride-inner { max-width: 680px; margin: 0 auto; }

    .tip-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1.2rem;
    }

    .tip-card {
      background: var(--cream);
      border-radius: 1rem;
      padding: 1.1rem;
    }

    .tip-card .t-icon { font-size: 1.5rem; margin-bottom: 0.4rem; }
    .tip-card h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.3rem; }
    .tip-card p { font-size: 0.82rem; color: var(--stone); }

    /* ── SEND A TIP ── */
    .tip-section {
      background: linear-gradient(135deg, #1a3329, var(--pine));
      color: var(--white);
      text-align: center;
      padding: 3rem 1.5rem;
    }

    .tip-section h2 { color: var(--gold); margin-bottom: 0.5rem; }
    .tip-section p { opacity: 0.85; max-width: 420px; margin: 0 auto 1.5rem; }

    .tip-btns {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
    }

    /* ── FOOTER ── */
    footer {
      background: #0f2019;
      color: rgba(255,255,255,0.55);
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 0.8rem;
    }

    footer a { color: var(--gold); text-decoration: none; }

    @media (max-width: 480px) {
      .about-grid { grid-template-columns: 1fr; }
      .tip-grid   { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- HERO -->
<header class="hero">
  <div class="hero-badge">🎖️ Army Veteran &nbsp;·&nbsp; Uber & Lyft Driver</div>
  <h1>Hey, I'm <span>Zachary.</span></h1>
  <p class="hero-sub">Your friendly Rocky Mountain driver - Colorado Springs, Woodland Park, Denver, and everywhere the mountains take us.</p>
  <div class="hero-chips">
    <span class="chip">🏔️ Rocky Mountain Region</span>
    <span class="chip">🎗️ Medically Retired Veteran</span>
    <span class="chip">👨‍👧‍👦 Dad of Five</span>
  </div>
  <div class="hero-btns">
    <a class="btn btn-uber" href="https://www.uber.com" target="_blank" rel="noopener">🚗 Uber</a>
    <a class="btn btn-lyft" href="https://www.lyft.com" target="_blank" rel="noopener">🟣 Lyft</a>
    <a class="btn btn-outline" href="#guides">Explore Colorado ↓</a>
  </div>
</header>

<!-- ABOUT -->
<section class="about">

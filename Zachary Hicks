</section>

<!-- FOOTER -->
<footer>
  <p>Made with ❤️ by Zachary Hicks &nbsp;·&nbsp; U.S. Army Veteran &nbsp;·&nbsp; Colorado Rockies</p>
  <p style="margin-top:0.4rem;">Serving Colorado Springs · Woodland Park · Denver &amp; beyond</p>
</footer>

</body>
</html>

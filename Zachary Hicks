</section>

<!-- RIDE INFO -->
<section class="ride-info">
  <div class="ride-inner">
    <span class="section-label">Ride With Me</span>
    <h2>What to expect in Zachary's car.</h2>
    <div class="tip-grid">
      <div class="tip-card">
        <div class="t-icon">🌡️</div>
